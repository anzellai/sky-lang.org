projectCard : String -> String -> String -> String -> String -> Element Msg
projectCard heading tag body linkLabel linkUrl =
    Ui.link
        ([ Ui.width (Ui.minimum 300 (Ui.fillPortion 1))
        , Ui.padding 24
        , Background.color C.brandWhite
        , Border.rounded 12
        , Border.width 1
        , Border.color C.border
        ]
            ++ C.cardShadow)
        { url = linkUrl
        , label = Ui.column
              [ Ui.spacing 12, Ui.width Ui.fill ]
              [ Ui.row
                    [Ui.width Ui.fill]
                    [ Ui.el
                          [ Font.size 18, Font.bold, Font.color C.brand ]
                          (Ui.text heading)
                    , Ui.el
                          [ Ui.alignRight
                          , Background.color C.accentSoft
                          , Font.color C.accent
                          , Font.size 11
                          , Font.semiBold
                          , Ui.paddingXY 10 4
                          , Border.rounded 12
                          ]
                          (Ui.text tag)
                    ]
              , Ui.paragraph
                    [ Font.size 14, Font.color C.subdued ]
                    [Ui.text body]
              , Ui.el
                    [ Font.size 13
                    , Font.color C.accent
                    , Font.semiBold
                    , Font.family "'SF Mono', 'Fira Code', monospace"
                    ]
                    (Ui.text linkLabel)
              ]
        }


