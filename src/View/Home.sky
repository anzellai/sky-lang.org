        ++ "M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83\"/>")


-- ─── Examples ──────────────────────────────────────────────────────
examples : Element Msg
examples =
    section_
        C.surface
        80
        (Ui.column
            [ Ui.spacing 48, Ui.width Ui.fill ]
            [ Ui.el
                  [ Ui.centerX, Font.size 32, Font.bold, Font.color C.brand ]
                  (Ui.text "See it in action")
            , Ui.wrappedRow
                  [ Ui.spacing 20, Ui.width Ui.fill ]
                  [ exampleCard "STD.UI FORMS" formsSnippet
                  , exampleCard "PATTERN MATCHING" patternSnippet
                  , exampleCard "DATABASE" dbSnippet
                  , exampleCard "ASYNC COMMANDS" asyncSnippet
                  , exampleCard "CONCURRENCY" concSnippet
                  , exampleCard "GO INTEROP" interopSnippet
                  ]
            ])


exampleCard : String -> String -> Element Msg
exampleCard heading snippet =
    Ui.column
        [ Ui.width (Ui.minimum 280 (Ui.fillPortion 1))
        , Ui.padding 20
        , Background.color C.brand
        , Border.rounded 10
        , Ui.spacing 12
        ]
        [ Ui.el
              [ Font.size 13
              , Font.semiBold
              , Font.color C.brandLight
              , Font.letterSpacing 5.0e-2
              ]
              (Ui.text heading)
        , Ui.el [Ui.width Ui.fill] (C.preCodeBlockSmall snippet)
        ]


formsSnippet : String
formsSnippet =
    """-- Typed onSubmit decodes formData
-- directly into a record arg
Ui.form [ Ui.onSubmit DoSignIn ]
    [ Input.email [] cfg.email
    , Input.currentPassword [] cfg.pwd
    , Ui.button [] btn
    ]"""


patternSnippet : String
patternSnippet =
    """describe shape =
    case shape of
        Circle r ->
            "circle r=" ++ String.fromFloat r
        Rectangle w h ->
            "rect" """


dbSnippet : String
dbSnippet =
    """import Std.Db as Db

-- reads sky.toml [database]
todos = Db.connect ()
    |> Task.andThenResult (\\db ->
        Db.queryDecode db
            "SELECT * FROM todos"
            [] todoDecoder)"""


asyncSnippet : String
asyncSnippet =
    """-- Run tasks in background goroutines
update msg model =
    case msg of
        FetchData ->
            ( model, Cmd.perform
                (Http.get "/api") GotData )"""


concSnippet : String
concSnippet =
    """-- Parallel HTTP requests (goroutines)
fetch =
    Task.parallel
        [ Http.get url1
        , Http.get url2
        ]
        |> Task.andThen handleAll"""


interopSnippet : String
interopSnippet =
    """import Stripe

-- whole-program DCE strips
-- unused symbols (76k -> only used)
charge = Stripe.newCharge ()
    |> Result.andThen ..."""


-- ─── Stats ─────────────────────────────────────────────────────────
stats : Element Msg
stats =
    section_
        C.brandWhite
        60
        (Ui.wrappedRow
            [ Ui.spacing 32, Ui.width Ui.fill ]
            [ statCard "35" "Examples"
            , statCard "485+" "Compiler tests"
            , statCard "3" "UI backends"
            , statCard "Haskell" "Compiler (GHC 9.4+)"
            ])


statCard : String -> String -> Element Msg
statCard num label =
    Ui.column
        [ Ui.width (Ui.fillPortion 1), Ui.centerX, Ui.spacing 4 ]
        [ Ui.el
              [ Ui.centerX, Font.size 36, Font.bold, Font.color C.accent ]
              (Ui.text num)
        , Ui.el
              [ Ui.centerX, Font.size 14, Font.color C.subdued ]
              (Ui.text label)
        ]


