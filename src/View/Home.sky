-- ─── Section frame ─────────────────────────────────────────────────
section_ : Ui.Color -> Int -> Element msg -> Element msg
section_ bg paddingY body =
    Ui.el
        [ Ui.width Ui.fill, Background.color bg, Ui.paddingXY 24 paddingY ]
        (Ui.el [ Ui.width (Ui.maximum C.maxContainer Ui.fill), Ui.centerX ] body)
