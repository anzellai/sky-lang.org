# Sky build artefacts
sky-out/
.skycache/
.skydeps/

# Dev databases (Litestream replicates prod elsewhere)
sky-lang.dev.db
sky-lang.dev.db-shm
sky-lang.dev.db-wal
*.db
*.db-shm
*.db-wal

# Local environment — never commit. The `.bak` line covers every
# editor-/manual-rotation backup pattern so a future `git add -A`
# can't grab them. Incident 2026-06-10: .env.production.bak slipped
# through and leaked 5 production secrets in commit 1853d2a (force-
# pushed off main + rotated).
.env
.env.*
*.env
*.env.bak
.env.local

# Cloudflare Origin cert + private key — uploaded by deploy.sh; never commit.
# Pattern uses `deploy/certs/*` (not `deploy/certs/`) so the README.md
# inside it can be re-included on the next-but-one line. Gitignore can't
# un-ignore a file whose PARENT dir is fully excluded.
deploy/certs/*

# OS noise
.DS_Store
*.swp
*~
!deploy/certs/README.md
