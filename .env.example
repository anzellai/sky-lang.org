# ─────────────────────────────────────────────────────────────────
# GitHub OAuth — the auth gate for /admin/*
# Create at https://github.com/settings/developers (OAuth App, not GitHub App)
# Callback URL: https://sky-lang.org/admin/auth/callback (prod)
#               http://localhost:8000/admin/auth/callback (dev — separate app recommended)
# ─────────────────────────────────────────────────────────────────
SKYLANG_GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
SKYLANG_GITHUB_CLIENT_SECRET=  # set in production env, not in committed .env

# Comma-separated GitHub logins allowed into /admin/* — v1 single-admin
SKYLANG_ADMIN_GITHUB_LOGINS=anzellai

# ─────────────────────────────────────────────────────────────────
# Session — app-owned (separate from GitHub secrets above)
# Used by Std.Auth.signTokenWithClaims to sign the sky_sid cookie.
# Must be ≥ 32 bytes random. Rotate periodically (TTL is 30 days,
# rotation invalidates existing sessions — users sign in again).
# Generate: `openssl rand -hex 32`
# ─────────────────────────────────────────────────────────────────
SKYLANG_SESSION_SECRET=

# ─────────────────────────────────────────────────────────────────
# Storage
# ─────────────────────────────────────────────────────────────────
SKYLANG_DB_PATH=/var/lib/sky-lang/sky-lang.db        # SQLite via Std.Db
SKYLANG_LITESTREAM_BUCKET=gs://sky-lang-org-litestream  # backup target (Phase 2)

# ─────────────────────────────────────────────────────────────────
# Optional — overrides + tuning
# ─────────────────────────────────────────────────────────────────
SKYLANG_BASE_URL=https://sky-lang.org    # used to construct OAuth redirect_uri
SKYLANG_DEV_MODE=0                       # 1 in dev — skips auth-cookie Secure flag for http://localhost

# ─────────────────────────────────────────────────────────────────
# Sky.Live runtime — separate namespace, framework-owned, configured per
# `docs/skylive` defaults. Listed here for clarity; usually leave alone.
# ─────────────────────────────────────────────────────────────────
SKY_LIVE_PORT=8000
SKY_LOG_LEVEL=info
SKY_AUTH_TOKEN_SECRET=                   # same as SKYLANG_SESSION_SECRET, OR alias to it in startup
ENV=production                            # gates dev console + dev banner off in production